<?xml version="1.0" encoding="UTF-8"?>
<xccdf-1.2:Tailoring xmlns:xccdf-1.2="http://checklists.nist.gov/xccdf/1.2"
                     id="xccdf_redoubt_tailoring_golang">
  <xccdf-1.2:benchmark href="ssg-rhel9-ds.xml"/>
  <xccdf-1.2:version time="2026-05-20T00:00:00">1</xccdf-1.2:version>

  <xccdf-1.2:Profile id="xccdf_redoubt_profile_stig_golang"
                     extends="xccdf_org.ssgproject.content_profile_stig">
    <xccdf-1.2:title>STIG for redoubt golang container image</xccdf-1.2:title>
    <xccdf-1.2:description>Tailored DISA STIG profile for the redoubt golang runtime image. Excludes rules inapplicable to ephemeral container images (partition layout, mount options managed by the container runtime, services not present in a runtime container, host-level packages) and rules covered by other pipeline tooling (Trivy for CVEs).</xccdf-1.2:description>

    <!-- ============================================================
         Partition layout
         Containers have a unified rootfs. Rules requiring separate
         partitions for /home, /tmp, /var, /var/log, etc., or partition
         encryption, do not apply to an immutable container image.
         ============================================================ -->
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_partition_for_home" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_partition_for_tmp" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_partition_for_var" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_partition_for_var_log" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_partition_for_var_log_audit" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_partition_for_var_tmp" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_encrypt_partitions" selected="false"/>

    <!-- ============================================================
         /dev/shm mount options
         The container runtime (Docker / Podman / containerd / Kubernetes)
         configures /dev/shm with appropriate nodev / noexec / nosuid
         options at runtime. The image cannot set these.
         ============================================================ -->
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_mount_option_dev_shm_nodev" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_mount_option_dev_shm_noexec" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_mount_option_dev_shm_nosuid" selected="false"/>

    <!-- ============================================================
         SSH
         There is no SSH server or client in a Go runtime container.
         These rules apply to interactive systems where SSH access
         is provided, not to ephemeral container workloads.
         ============================================================ -->
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_package_openssh-clients_installed" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_harden_sshd_ciphers_openssh_conf_crypto_policy" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_harden_sshd_macs_openssh_conf_crypto_policy" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_ssh_keys_passphrase_protected" selected="false"/>

    <!-- ============================================================
         Host-level package requirements
         These packages (crypto-policies, gnutls-utils, nss-tools,
         subscription-manager) are intended for full RHEL hosts.
         UBI Micro is a minimal runtime base and intentionally omits
         them.
         ============================================================ -->
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_package_crypto-policies_installed" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_package_gnutls-utils_installed" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_package_nss-tools_installed" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_package_subscription-manager_installed" selected="false"/>

    <!-- ============================================================
         Runtime-configured items
         The crypto-policies symlinks and /etc/hosts are configured
         by the deployment environment (host crypto policy, K8s DNS
         config, etc.), not by the image itself.
         ============================================================ -->
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_configure_crypto_policy" selected="false"/>
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_network_configure_name_resolution" selected="false"/>

    <!-- ============================================================
         Covered by other pipeline tooling
         security_patches_up_to_date relies on live OVAL evaluation
         against a vulnerability database. Trivy in the redoubt
         pipeline already provides continuous CVE coverage and
         gates HIGH/CRITICAL fixable CVEs.
         ============================================================ -->
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_security_patches_up_to_date" selected="false"/>

  </xccdf-1.2:Profile>
</xccdf-1.2:Tailoring>
